<!DOCTYPE html>

<html lang="en">
<head>
<title>GetEm Gone Pest Control v4</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black:#080a0f; --dark:#0d1117; --panel:#111620;
  --blue:#1a6fff; --bluehi:#4d8fff; --blueglow:rgba(26,111,255,0.18);
  --bluedim:rgba(26,111,255,0.08); --white:#f0f4ff; --silver:#8a9ab8;
  --mid:#4a5570; --border:rgba(26,111,255,0.2);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}
body::after{content:'';position:fixed;inset:0;z-index:9998;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 5%;background:rgba(8,10,15,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(–border);height:64px;gap:1rem;}
.nav-logo{font-family:‘Barlow Condensed’,sans-serif;font-size:1.5rem;font-weight:900;letter-spacing:3px;text-transform:uppercase;text-decoration:none;color:var(–white);}
.nav-logo span{color:var(–blue);}
nav ul{display:flex;list-style:none;gap:0.3rem;flex-wrap:nowrap;}
nav ul a{display:block;padding:0.4rem 0.7rem;text-decoration:none;font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(–silver);border:1px solid transparent;border-radius:2px;transition:color 0.2s,border-color 0.2s,background 0.2s;}
nav ul a:hover{color:var(–blue);border-color:var(–border);background:var(–bluedim);}
.nav-cta{background:var(–blue)!important;color:var(–white)!important;border-color:var(–blue)!important;font-weight:700!important;}
.nav-cta:hover{background:var(–bluehi)!important;}
.account-btn{background:var(–bluedim);border:1px solid var(–border);color:var(–white);padding:0.4rem 0.9rem;border-radius:2px;font-family:‘Barlow’,sans-serif;font-size:0.75rem;font-weight:600;letter-spacing:0.08em;cursor:pointer;white-space:nowrap;transition:background 0.2s;}
.account-btn:hover{background:var(–blue);}

/* OWNER TAB */
.owner-tab{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:500;background:var(–panel);border:1px solid var(–border);border-right:none;border-radius:6px 0 0 6px;padding:0.6rem 0.5rem;display:flex;flex-direction:column;align-items:center;gap:0.3rem;cursor:pointer;transition:background 0.2s,border-color 0.2s;box-shadow:-3px 0 15px rgba(0,0,0,0.3);}
.owner-tab:hover{background:var(–bluedim);border-color:var(–blue);}
.owner-tab-label{font-size:0.6rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(–silver);writing-mode:vertical-rl;}

/* HERO */
#hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:6rem 5% 4rem;position:relative;overflow:hidden;background:var(–dark);}
#hero::before{content:’’;position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(var(–border) 1px,transparent 1px),linear-gradient(90deg,var(–border) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%);opacity:0.6;}
.hero-tag{display:inline-flex;align-items:center;gap:0.5rem;background:var(–bluedim);border:1px solid var(–border);color:var(–blue);font-size:0.7rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;padding:0.4rem 0.9rem;border-radius:2px;margin-bottom:1rem;animation:fadeUp 0.5s ease both;}
.hero-tag::before{content:’’;width:6px;height:6px;border-radius:50%;background:var(–blue);animation:blink 1.5s infinite;}
.hero-slogan{font-size:0.95rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(–silver);margin-bottom:1.2rem;animation:fadeUp 0.5s 0.06s ease both;}
.hero-slogan span{color:var(–blue);}
h1.hero-h1{font-family:‘Barlow Condensed’,sans-serif;font-size:clamp(4rem,8vw,8rem);font-weight:900;line-height:0.9;text-transform:uppercase;letter-spacing:2px;color:var(–white);animation:fadeUp 0.5s 0.1s ease both;}
h1.hero-h1 .blue{color:var(–blue);}
h1.hero-h1 .outline{-webkit-text-stroke:2px var(–white);color:transparent;}
.hero-rule{width:80px;height:2px;background:linear-gradient(90deg,var(–blue),transparent);margin:2rem 0;animation:fadeUp 0.5s 0.15s ease both;}
.hero-desc{font-size:1rem;font-weight:300;line-height:1.7;color:var(–silver);max-width:420px;animation:fadeUp 0.5s 0.2s ease both;}
.hero-btns{display:flex;gap:1rem;margin-top:2.5rem;flex-wrap:wrap;animation:fadeUp 0.5s 0.25s ease both;}
.btn-blue{background:var(–blue);color:var(–white);padding:0.85rem 2rem;border-radius:2px;font-family:‘Barlow Condensed’,sans-serif;font-size:1rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:background 0.2s,transform 0.15s,box-shadow 0.2s;box-shadow:0 0 20px rgba(26,111,255,0.3);}
.btn-blue:hover{background:var(–bluehi);transform:translateY(-2px);}
.btn-ghost{border:1px solid var(–border);color:var(–silver);padding:0.85rem 2rem;border-radius:2px;font-family:‘Barlow Condensed’,sans-serif;font-size:1rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:border-color 0.2s,color 0.2s;}
.btn-ghost:hover{border-color:var(–blue);color:var(–blue);}
.hero-metrics{display:flex;gap:2.5rem;margin-top:3rem;border-top:1px solid var(–border);padding-top:2rem;animation:fadeUp 0.5s 0.3s ease both;}
.metric-val{font-family:‘Barlow Condensed’,sans-serif;font-size:2.2rem;font-weight:900;color:var(–blue);line-height:1;}
.metric-label{font-size:0.7rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(–mid);margin-top:0.3rem;}
.hero-right{display:flex;justify-content:center;align-items:center;position:relative;z-index:1;animation:fadeUp 0.6s 0.2s ease both;}
.radar-wrap{position:relative;width:360px;height:360px;}
.radar-circle{position:absolute;border-radius:50%;border:1px solid var(–border);top:50%;left:50%;transform:translate(-50%,-50%);}
.radar-circle:nth-child(1){width:100%;height:100%;}
.radar-circle:nth-child(2){width:70%;height:70%;}
.radar-circle:nth-child(3){width:40%;height:40%;}
.radar-sweep{position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,transparent 80%,rgba(26,111,255,0.4) 100%);animation:sweep 3s linear infinite;}
.radar-crosshair{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:100%;height:1px;background:var(–border);}
.radar-crosshair::after{content:’’;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(90deg);width:100%;height:1px;background:var(–border);}
.radar-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60px;height:60px;border-radius:50%;background:var(–panel);border:2px solid var(–blue);display:flex;align-items:center;justify-content:center;font-size:1.8rem;box-shadow:0 0 20px var(–blueglow);}
.radar-dot{position:absolute;width:8px;height:8px;border-radius:50%;background:var(–blue);box-shadow:0 0 10px var(–blue);animation:dotPulse 2s ease-in-out infinite;}
.radar-dot:nth-child(5){top:20%;left:65%;animation-delay:0.3s;}
.radar-dot:nth-child(6){top:60%;left:25%;animation-delay:0.8s;}
.radar-dot:nth-child(7){top:75%;left:70%;animation-delay:1.4s;}
.radar-label{position:absolute;font-size:0.65rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(–blue);opacity:0.7;}
.radar-label:nth-of-type(1){top:5%;left:50%;transform:translateX(-50%);}
.radar-label:nth-of-type(2){bottom:5%;left:50%;transform:translateX(-50%);}
.radar-label:nth-of-type(3){left:2%;top:50%;transform:translateY(-50%);}
.radar-label:nth-of-type(4){right:2%;top:50%;transform:translateY(-50%);}

/* SECTION COMMON */
.sec-eyebrow{font-size:0.7rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(–blue);margin-bottom:0.75rem;}
h2.sec-h2{font-family:‘Barlow Condensed’,sans-serif;font-size:clamp(2.5rem,4vw,4rem);font-weight:900;text-transform:uppercase;letter-spacing:2px;color:var(–white);line-height:0.95;}
h2.sec-h2 span{color:var(–blue);}

/* SERVICES */
#services{padding:7rem 5%;background:var(–black);}
.sec-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;flex-wrap:wrap;gap:1.5rem;}
.sec-note{max-width:300px;font-size:0.9rem;color:var(–silver);line-height:1.6;font-weight:300;}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(–border);border:1px solid var(–border);}
.svc-card{background:var(–dark);padding:2rem 1.8rem;position:relative;overflow:hidden;transition:background 0.25s;cursor:default;}
.svc-card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:var(–blue);transform:scaleX(0);transform-origin:left;transition:transform 0.3s ease;}
.svc-card:hover{background:var(–panel);}
.svc-card:hover::before{transform:scaleX(1);}
.svc-card:hover .svc-arrow{opacity:1;transform:translateX(0);}
.svc-ico{font-size:2rem;margin-bottom:1.2rem;display:block;}
.svc-name{font-family:‘Barlow Condensed’,sans-serif;font-size:1.4rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(–white);margin-bottom:0.5rem;}
.svc-text{font-size:0.85rem;color:var(–silver);line-height:1.6;font-weight:300;}
.svc-arrow{position:absolute;bottom:1.5rem;right:1.5rem;color:var(–blue);font-size:1.2rem;opacity:0;transform:translateX(-6px);transition:opacity 0.2s,transform 0.2s;}

/* ABOUT */
#about{padding:7rem 5%;background:var(–dark);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative;overflow:hidden;}
.about-left .terminal-box{background:var(–black);border:1px solid var(–border);border-radius:4px;overflow:hidden;box-shadow:0 0 40px rgba(26,111,255,0.1);}
.terminal-bar{background:var(–panel);padding:0.75rem 1rem;display:flex;align-items:center;gap:0.5rem;border-bottom:1px solid var(–border);}
.t-dot{width:10px;height:10px;border-radius:50%;}
.t-dot:nth-child(1){background:#ff5f57;} .t-dot:nth-child(2){background:#febc2e;} .t-dot:nth-child(3){background:#28c840;}
.t-title{font-size:0.72rem;font-weight:600;letter-spacing:0.1em;color:var(–mid);margin:0 auto;}
.terminal-body{padding:1.5rem;}
.t-line{font-size:0.85rem;line-height:2;font-family:monospace;}
.t-prompt{color:var(–blue);} .t-cmd{color:var(–white);} .t-out{color:#4ade80;} .t-out.warn{color:var(–blue);} .t-out.dim{color:var(–silver);}
.cursor{display:inline-block;width:8px;height:14px;background:var(–blue);vertical-align:middle;animation:blink 1s infinite;}
.about-body{font-size:0.97rem;color:var(–silver);line-height:1.8;font-weight:300;margin-top:1.5rem;}
.about-body p+p{margin-top:1rem;}
.feature-list{margin-top:2rem;display:flex;flex-direction:column;gap:0.75rem;}
.feature-item{display:flex;align-items:center;gap:0.75rem;font-size:0.88rem;font-weight:500;color:var(–white);}
.feature-item::before{content:’//’;font-family:‘Barlow Condensed’,sans-serif;font-weight:700;color:var(–blue);font-size:0.9rem;letter-spacing:-1px;}
.about-cta{margin-top:2.5rem;}

/* REVIEWS */
#reviews{padding:7rem 5%;background:var(–black);}
.reviews-sub{font-size:0.95rem;color:var(–silver);margin-top:0.75rem;margin-bottom:3rem;font-weight:300;}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;background:var(–border);border:1px solid var(–border);margin-bottom:2rem;}
.review-card{background:var(–dark);padding:2rem;display:flex;flex-direction:column;gap:1rem;transition:background 0.2s;}
.review-card:hover{background:var(–panel);}
.review-stars{color:var(–blue);font-size:1rem;letter-spacing:2px;}
.review-text{font-size:0.88rem;color:var(–silver);line-height:1.7;font-style:italic;flex:1;}
.review-author{display:flex;align-items:center;gap:0.75rem;margin-top:auto;}
.review-avatar{width:38px;height:38px;border-radius:50%;background:var(–bluedim);border:1px solid var(–border);display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:700;color:var(–blue);flex-shrink:0;}
.review-name{font-size:0.85rem;font-weight:700;color:var(–white);}
.review-date{font-size:0.72rem;color:var(–mid);margin-top:0.1rem;}
.review-cta-card{background:var(–bluedim)!important;border-left:3px solid var(–blue);text-align:center;align-items:center;justify-content:center;}
.review-cta-card h3{font-family:‘Barlow Condensed’,sans-serif;font-size:1.4rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;color:var(–white);}
.review-cta-card p{font-size:0.85rem;color:var(–silver);line-height:1.6;}
.reviews-summary{display:flex;align-items:center;justify-content:center;gap:3rem;flex-wrap:wrap;background:var(–dark);border:1px solid var(–border);padding:2rem;margin-top:2rem;}
.summary-score{text-align:center;}
.score-num{font-family:‘Barlow Condensed’,sans-serif;font-size:3.5rem;font-weight:900;color:var(–blue);line-height:1;}
.score-stars{color:var(–blue);font-size:1rem;letter-spacing:3px;margin:0.2rem 0;}
.score-label{font-size:0.7rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(–mid);}
.summary-divider{width:1px;height:50px;background:var(–border);}
.summary-stat{text-align:center;}
.s-val{font-family:‘Barlow Condensed’,sans-serif;font-size:2rem;font-weight:900;color:var(–white);line-height:1;}
.s-label{font-size:0.7rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(–mid);margin-top:0.3rem;}

/* UPLOAD */
#upload{padding:7rem 5%;background:var(–dark);}
.upload-sub{font-size:0.95rem;color:var(–silver);margin-top:0.75rem;margin-bottom:3rem;font-weight:300;max-width:600px;}
.upload-layout{display:grid;grid-template-columns:1.4fr 1fr;gap:3rem;align-items:start;}
.upload-box{background:var(–black);border:1px solid var(–border);border-radius:4px;padding:2.5rem;}
.upload-tabs{display:flex;gap:0.5rem;margin-bottom:1rem;}
.upload-tab{flex:1;padding:0.6rem;border-radius:2px;background:var(–panel);border:1px solid var(–border);color:var(–silver);font-family:‘Barlow’,sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;transition:background 0.2s,color 0.2s,border-color 0.2s;}
.upload-tab.active{background:var(–bluedim);border-color:var(–blue);color:var(–white);}
.upload-dropzone{border:2px dashed var(–border);border-radius:4px;padding:2.5rem 1rem;text-align:center;cursor:pointer;transition:border-color 0.2s,background 0.2s;margin-bottom:1rem;}
.upload-dropzone:hover,.upload-dropzone.drag-over{border-color:var(–blue);background:var(–bluedim);}
.dz-icon{font-size:2.5rem;margin-bottom:0.5rem;}
.dz-text{font-family:‘Barlow Condensed’,sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(–white);}
.dz-sub{font-size:0.78rem;color:var(–mid);margin-top:0.3rem;}
.upload-preview{display:grid;grid-template-columns:repeat(4,1fr);gap:0.5rem;margin-bottom:1rem;}
.preview-thumb{aspect-ratio:1;border-radius:3px;overflow:hidden;border:1px solid var(–border);position:relative;}
.preview-thumb img{width:100%;height:100%;object-fit:cover;}
.preview-thumb .remove-btn{position:absolute;top:3px;right:3px;background:rgba(0,0,0,0.7);color:white;border:none;border-radius:50%;width:18px;height:18px;font-size:0.6rem;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.preview-thumb.video-thumb{background:var(–panel);}
.preview-thumb .video-label{position:absolute;bottom:3px;left:3px;background:rgba(0,0,0,0.75);color:var(–blue);font-size:0.6rem;font-weight:700;padding:1px 4px;border-radius:2px;letter-spacing:0.05em;text-transform:uppercase;}
.preview-thumb .video-icon{font-size:1.8rem;display:flex;align-items:center;justify-content:center;width:100%;height:100%;}
.file-count{font-size:0.78rem;color:var(–blue);font-weight:600;letter-spacing:0.08em;margin-bottom:0.5rem;}
.upload-privacy{font-size:0.75rem;color:var(–mid);text-align:center;margin-bottom:1rem;}
.upload-ok{text-align:center;padding:2.5rem 1rem;}
.upload-ok h4{font-family:‘Barlow Condensed’,sans-serif;font-size:1.8rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(–blue);margin:0.5rem 0;}
.upload-info{display:flex;flex-direction:column;gap:1.5rem;}
.upl-tip{background:var(–panel);border:1px solid var(–border);border-radius:4px;padding:1.5rem;display:flex;gap:1rem;}
.upl-tip-icon{font-size:1.5rem;flex-shrink:0;}
.upl-tip-title{font-family:‘Barlow Condensed’,sans-serif;font-size:1rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(–white);margin-bottom:0.7rem;}
.upl-tip-list{list-style:none;display:flex;flex-direction:column;gap:0.4rem;}
.upl-tip-list li{font-size:0.83rem;color:var(–silver);padding-left:1rem;position:relative;}
.upl-tip-list li::before{content:’>’;color:var(–blue);position:absolute;left:0;font-size:0.75rem;}
.upl-contact-note{background:var(–bluedim);border:1px solid var(–border);border-left:3px solid var(–blue);padding:1rem 1.2rem;border-radius:2px;font-size:0.83rem;color:var(–silver);line-height:1.6;}
.upl-contact-note strong{color:var(–white);}

/* PAYMENT */
#payment{padding:7rem 5%;background:var(–panel);}
.pay-sub{font-size:0.95rem;color:var(–silver);margin-top:0.75rem;margin-bottom:3rem;font-weight:300;}
.pay-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;}
.pay-card{background:var(–dark);border:1px solid var(–border);border-radius:4px;padding:2.5rem;}
.pay-card.pay-alt{display:flex;flex-direction:column;}
.pay-icon{font-size:2.5rem;margin-bottom:0.8rem;}
.pay-name{font-family:‘Barlow Condensed’,sans-serif;font-size:1.6rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(–white);margin-bottom:0.5rem;}
.pay-desc{font-size:0.88rem;color:var(–silver);line-height:1.6;margin-bottom:1.8rem;}
.pay-secure{font-size:0.75rem;color:var(–mid);text-align:center;margin-top:1rem;}
.pay-ok{text-align:center;padding:2rem 1rem;}
.pay-ok h4{font-family:‘Barlow Condensed’,sans-serif;font-size:1.8rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(–blue);margin:0.5rem 0;}
.pay-methods{display:flex;flex-direction:column;gap:1rem;margin-bottom:1.5rem;}
.pay-method{display:flex;align-items:center;gap:1rem;background:var(–black);border:1px solid var(–border);padding:1rem 1.2rem;border-radius:3px;transition:border-color 0.2s;}
.pay-method:hover{border-color:var(–blue);}
.pay-method-icon{font-size:1.6rem;}
.pay-method-name{font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(–white);}
.pay-method-handle{font-size:0.9rem;color:var(–blue);font-weight:500;margin-top:0.15rem;}
.pay-note{background:var(–bluedim);border:1px solid var(–border);border-left:3px solid var(–blue);padding:1rem 1.2rem;border-radius:2px;margin-top:auto;font-size:0.82rem;color:var(–silver);line-height:1.6;}
.pay-note strong{color:var(–white);}

/* CONTACT */
#contact{padding:7rem 5%;background:var(–black);}
.contact-layout{display:grid;grid-template-columns:1fr 1.6fr;gap:4rem;margin-top:3.5rem;}
.c-info h3{font-family:‘Barlow Condensed’,sans-serif;font-size:1.3rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(–white);margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(–border);}
.c-item{display:flex;gap:1rem;margin-bottom:1.5rem;align-items:flex-start;}
.c-item-icon{width:40px;height:40px;background:var(–bluedim);border:1px solid var(–border);border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;}
.c-item-label{font-size:0.68rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(–blue);}
.c-item-val{font-size:0.95rem;font-weight:500;color:var(–white);margin-top:0.2rem;}
.saturday-note{background:var(–bluedim);border:1px solid var(–border);border-left:3px solid var(–blue);padding:1rem 1.2rem;border-radius:2px;margin-bottom:1.5rem;font-size:0.83rem;color:var(–silver);line-height:1.6;}
.saturday-note strong{color:var(–white);}
